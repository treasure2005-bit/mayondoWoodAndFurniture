extends layout.pug

block head
  link(rel='stylesheet' href='/css/loadingform.css')
  link(href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css' rel='stylesheet')
  style.
    .error-message {
      background-color: #f8d7da;
      color: #721c24;
      padding: 12px;
      margin-bottom: 20px;
      border: 1px solid #f5c6cb;
      border-radius: 4px;
      text-align: center;
      display: none;
    }
    
    .success-message {
      background-color: #d4edda;
      color: #155724;
      padding: 12px;
      margin-bottom: 20px;
      border: 1px solid #c3e6cb;
      border-radius: 4px;
      text-align: center;
      display: none;
    }
    
    .field-error {
      color: #dc3545;
      font-size: 13px;
      margin-top: 5px;
      display: none;
    }
    
    input.error,
    select.error,
    textarea.error {
      border: 2px solid #dc3545 !important;
    }
    
    .form-group {
      margin-bottom: 20px;
    }

block content
  nav.navbar
    .nav-brand
      i.fas.fa-boxes
      | MWF Inventory
    .nav-buttons
      a(href='/attendant')
        i.fas.fa-home
        | Dashboard
      a.logout(href='/login')
        i.fas.fa-sign-out-alt
        | Logout

  .card.loading-card
    .card-header
      .card-title
        h3 NEW LOADING OPERATION
        p Record products being loaded for delivery
    
    .card-content
      #errorMessage.error-message
      #successMessage.success-message
      
      form#loadingForm(action='/loadingform' method='POST')
        .form-grid
          
          .form-section
            h4 Loading Details
            .form-group
              label(for='loadingDate') Date & Time *
              input#loadingDate(type='datetime-local' name='loadingDate')
              .field-error#loadingDateError
            
            .form-group
              label(for='vehicleInfo') Vehicle Information *
              input#vehicleInfo(type='text' name='vehicleInfo' placeholder='Vehicle plate/ID (e.g., UAX 123A)')
              .field-error#vehicleInfoError
            
            .form-group
              label(for='driverName') Driver Name *
              input#driverName(type='text' name='driverName' placeholder='Driver assigned')
              .field-error#driverNameError
            
            .form-group
              label(for='destination') Destination *
              input#destination(type='text' name='destination' placeholder='Delivery location')
              .field-error#destinationError

          .form-section
            h4 Products to Load
            .product-selection
              .form-group
                label(for='productCategory') Product Category *
                select#productCategory(name='productCategory')
                  option(value='') Select category
                  option(value='timber') Wood Products 
                  option(value='furniture') Furniture
                .field-error#productCategoryError
              
              .form-group
                label(for='productName') Product Name *
                select#productName(name='productName')
                  option(value='') Select product 
                  option(value='Beds') Beds
                  option(value='Timber') Timber
                  option(value='Sofa') Sofa
                  option(value='Poles') Poles
                  option(value='Dining tables') Dining Tables
                  option(value='hard wood') Hard wood
                  option(value='cupboards') Cupboards
                  option(value='soft wood') Soft wood
                  option(value='Drawers') Drawers
                  option(value='Home furniture') Home furniture 
                  option(value='Office furniture') Office furniture
                .field-error#productNameError
              
              .form-row
                .form-group.half-width
                  label(for='quantity') Quantity *
                  input#quantity(type='number' name='quantity' min='1' placeholder='Enter quantity')
                  .field-error#quantityError
                
                .form-group.half-width
                  label(for='unit') Unit *
                  select#unit(name='unit')
                    option(value='') Select unit
                    option(value='pieces') Pieces
                    option(value='kg') Kilograms
                    option(value='tons') Tons
                    option(value='cubic_meters') Cubic Meters
                    option(value='sets') Sets
                  .field-error#unitError

          .form-section
            h4 Additional Information
            .form-group
              label(for='attendantName') Attendant Name *
              input#attendantName(type='text' name='attendantName' placeholder='Your name')
              .field-error#attendantNameError
            
            .form-group
              label(for='specialInstructions') Special Instructions
              textarea#specialInstructions(name='specialInstructions' rows='3' placeholder='Any special handling notes...')
              .field-error#specialInstructionsError
            
            .form-group
              label(for='priority') Priority Level *
              select#priority(name='priority')
                option(value='') Select priority
                option(value='normal') Normal
                option(value='urgent') Urgent
                option(value='low') Low Priority
              .field-error#priorityError

        .card-actions
          button.btn-secondary(type='button' onclick='window.history.back()')