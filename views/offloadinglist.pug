extends layout.pug

block head
  link(rel='stylesheet' href='/css/offloadinglist.css')
  link(href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css' rel='stylesheet')

block content
  nav.navbar
    .nav-brand
      i.fas.fa-boxes
      | MWF Inventory
    .nav-buttons
      a(href='/attendant')
        i.fas.fa-home
        | Dashboard
      a.logout(href='/login')
        i.fas.fa-sign-out-alt
        | Logout

  .container
    .page-header
      h1
        i.fas.fa-truck-ramp
        | Offloading Operations List
      p View, manage, and track all offloading operations

    .action-bar
      .search-box
        input#searchInput(type='text' placeholder='Search by reference, product, driver...')
        i.fas.fa-search
      
      a.btn-add(href='/offloadingform')
        i.fas.fa-plus-circle
        | Add New Offloading

    .table-container
      if offloadings && offloadings.length > 0
        table#offloadingTable
          thead
            tr
              th Delivery Ref
              th Date & Time
              th Product
              th Quantity
              th Unit
              th Status
              th Condition
              th Driver
              th Actions
          tbody
            - for (let i = 0; i < offloadings.length; i++)
              - const item = offloadings[i]
              tr
                td= item.deliveryReference
                td= new Date(item.offloadingDate).toLocaleString()
                td= item.productName
                td= item.actualQuantity + ' / ' + (item.expectedQuantity || item.actualQuantity)
                td= item.unit
                td
                  if item.discrepancy === 'match'
                    span.status-badge.status-match ✓ Match
                  else if item.discrepancy === 'shortage'
                    span.status-badge.status-shortage ⚠ Shortage
                  else if item.discrepancy === 'excess'
                    span.status-badge.status-excess ⚠ Excess
                td
                  - const conditionText = item.productCondition.charAt(0).toUpperCase() + item.productCondition.slice(1)
                  span(class='condition-badge condition-' + item.productCondition)= conditionText
                td= item.driverName
                td
                  .action-buttons
                    a.btn-action.btn-edit(href='/offloadingform/' + item._id + '/edit')
                      i.fas.fa-edit
                    button.btn-action.btn-delete(onclick='confirmDelete("' + item._id + '", "' + item.deliveryReference + '")')
                      i.fas.fa-trash
      else
        .empty-state
          i.fas.fa-inbox
          h3 No Offloading Operations Yet
          p Start by adding your first offloading operation
          a.btn-add(href='/offloadingform')
            i.fas.fa-plus-circle
            | Add New Offloading

  #deleteModal.modal
    .modal-content
      .modal-header
        i.fas.fa-exclamation-triangle
        h3 Confirm Delete
      .modal-body
        p Are you sure you want to delete this offloading operation? This action cannot be undone.
        p
          strong Reference: 
          span#deleteRef
      .modal-actions
        button.btn-cancel(onclick='closeDeleteModal()') Cancel
        button.btn-confirm-delete(onclick='deleteOffloading()') Delete

  script.
    let deleteId = null;
    let deleteReference = null;

    function showNotification(message, type = 'success') {
      const notification = document.createElement('div');
      notification.className = `notification notification-${type}`;
      notification.innerHTML = `
        <i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'}"></i>
        <span>${message}</span>
      `;
      document.body.appendChild(notification);
      setTimeout(() => notification.remove(), 3000);
    }

    const searchInput = document.getElementById('searchInput');
    if (searchInput) {
      searchInput.addEventListener('input', function(e) {
        const searchTerm = e.target.value.toLowerCase();
        const rows = document.querySelectorAll('#offloadingTable tbody tr');
        rows.forEach(row => {
          const text = row.textContent.toLowerCase();
          row.style.display = text.includes(searchTerm) ? '' : 'none';
        });
      });
    }

    function confirmDelete(id, ref) {
      deleteId = id;
      deleteReference = ref;
      document.getElementById('deleteRef').textContent = ref;
      document.getElementById('deleteModal').classList.add('active');
    }

    function closeDeleteModal() {
      document.getElementById('deleteModal').classList.remove('active');
      deleteId = null;
      deleteReference = null;
    }

    function deleteOffloading() {
      if (deleteId) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/offloadingform/${deleteId}/delete`;
        document.body.appendChild(form);
        form.submit();
      }
    }

    document.getElementById('deleteModal').addEventListener('click', function(e) {
      if (e.target === this) {
        closeDeleteModal();
      }
    });