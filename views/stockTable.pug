extends layout.pug

block head
  link(rel='stylesheet' href='/css/style.css')

block content
  nav.navbar
      .nav-brand
        i.fas.fa-boxes
        | MWF Inventory
      .nav-buttons
        a(href='/dashboard')
          i.fas.fa-home
          | Dashboard
        a.logout(href='/login')
          i.fas.fa-sign-out-alt
          | Logout

  .container
    .header-section
      h3 CURRENT STOCK
      a.btn.btn-add-stock(href='/registerStock') 
        | ➕ ADD STOCK
    
    table#stockTable
      thead
        tr
          th NAME
          th TYPE
          th COST PRICE
          th SELLING PRICE
          th QUANTITY
          th SUPPLIER
          th DATE BOUGHT
          th QUALITY
          th COLOR
          th MEASUREMENT
          th ACTIONS 
      tbody
        if items && items.length 
          each item in items 
            tr 
              td #{item.productName}
              td #{item.productType}
              td UGX #{item.costPrice.toLocaleString()}
              td UGX #{item.productPrice.toLocaleString()}
              td #{item.quantity}
              td #{item.supplierName}
              td #{moment(item.date).format("DD/MM/YYYY")}
              td #{item.quality}
              td 
                span(style=`background-color: ${item.color}; padding: 4px 8px; border-radius: 3px; color: white;`) #{item.color}
              td #{item.measurement}
              td 
                .action-buttons
                  a.btn.btn-edit(href=`/editstock/${item._id}`) 
                    | ✏️ EDIT
                  form(method='post' action=`/deleteStock/${item._id}` style='display: inline;')
                    button.btn.btn-delete(type='submit' onclick="return confirm('Are you sure you want to delete this item?')") 
                      | 🗑️ DELETE
                      
        else
          tr
            td(colspan='11' style='text-align: center; padding: 20px; color: #6c757d;') 
              | 📦 No stock available
              br
              a.btn.btn-primary(href='/registerStock' style='margin-top: 10px;') Add Your First Item